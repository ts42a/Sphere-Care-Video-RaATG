# Copy to docker/.env before starting:
#   cp docker/.env.example docker/.env

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sphere_care

DATABASE_URL=postgresql://postgres:postgres@db:5432/sphere_care
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Disable heavy workers for a lighter default container (enable when models are mounted)
SCVAM_ENABLED=false
SCVAM_WORKER_AUTOSTART=false
AI_PIPELINE_ENABLED=false

VAULT_STORAGE_ROOT=/app/databases

# LiveKit (optional — required for realtime call media)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LLM summaries (optional)
AI_LLM_PROVIDER=none
