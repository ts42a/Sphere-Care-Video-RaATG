# Copy to frontend_client/.env before running the mobile app:
#   Copy-Item .env.example .env

EXPO_PUBLIC_USE_MOCK_API=false
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
EXPO_PUBLIC_WS_BASE_URL=ws://127.0.0.1:8000

# HOST guide:
#   Web / same machine  -> 127.0.0.1
#   Android emulator    -> 10.0.2.2
#   Real phone          -> your computer LAN IP (ipconfig)

# Do not put backend secrets (OpenAI keys, LiveKit, etc.) in this file.
