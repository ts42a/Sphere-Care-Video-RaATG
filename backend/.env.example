DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sphere_care
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Gmail SMTP (used by password_reset.py AND auth.py OTP)
GMAIL_ADDRESS=your_email@example.com
GMAIL_APP_PASS=YOUR_GMAIL_APP_PASSWORD

# auth.py OTP also reads these (same Gmail account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_FROM=your_email@example.com

# Frontend URL (for password reset link)
FRONTEND_URL=http://localhost:8000/src/pages

# LiveKit (server-side token minting for realtime calls)
LIVEKIT_URL=wss://YOUR_LIVEKIT_INSTANCE.livekit.cloud
LIVEKIT_API_KEY=YOUR_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=YOUR_LIVEKIT_API_SECRET
